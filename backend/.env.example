# ====== 실제 .env 는 EC2 /opt/flowmeet/.env 에 두고 커밋하지 않는다 ======

# ---------- Registry ----------
DOCKERHUB_USERNAME=
IMAGE_TAG=latest

# ---------- Domain / TLS ----------
DOMAIN=api.flowmeet.kr
CERTBOT_EMAIL=

# ---------- RDS (PostgreSQL) ----------
DB_HOST=
DB_PORT=5432
DB_NAME=flowmeet
DB_USERNAME=
DB_PASSWORD=

# ---------- JWT ----------
JWT_SECRET_KEY=

# ---------- OAuth2 Google ----------
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=

# ---------- Mail (SMTP) ----------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ---------- AWS S3 ----------
S3_BUCKET=static.flowmeet.kr
S3_REGION=ap-northeast-2
S3_CDN_URL=static.flowmeet.kr

# ---------- Google Meet (Calendar API) ----------
# OAuth2 사용자 동의 흐름으로 회의 host 의 Calendar 에 이벤트를 만든다.
# false 또는 미설정 시 stub 폴백(LocalMeetingRoomProvider)으로 동작.
# OAUTH2_GOOGLE_CLIENT_ID / OAUTH2_GOOGLE_CLIENT_SECRET 을 그대로 사용한다.
GOOGLE_MEET_ENABLED=false
GOOGLE_APP_NAME=FlowMeet
GOOGLE_CALENDAR_ID=primary
GOOGLE_MEET_TIMEZONE=Asia/Seoul

# ---------- JVM ----------
# t3.micro 에서 컨테이너 mem_limit(800m) 의 60% 를 힙으로 사용 → Xmx ≈ 480MB
JAVA_OPTS=-XX:MaxRAMPercentage=60.0 -XX:+ExitOnOutOfMemoryError
